@using PreventDeskTool
@model IEnumerable<PreventDeskTool.Models.Videos>
@{
    Layout = null;
}


<div class="row">
<div class="col-12">
    <div class="card card-primary">
        <div class="card-header">
            <h4 class="card-title">Videos</h4>
        </div>
        <div class="card-body">
            <div class="row">
                @if(Model.Count()>0 && Model !=null)
                {

                @foreach (PreventDeskTool.Models.Videos video in Model)
                {
                    <div class="col-sm-4">
                  <a class="btn btn-primary" id="DeleteVideo" data-id="@video.VideoId">Delete</a>
                    <a href="#">
                        <video id="showvideo" src="~/Videos/@video.VideoPath" controls width="400" height="260">                  
                        </video>

                    </a>
                    </div>
                }
              }

             else
            {
                <h3 class="text-danger text-center">NO Videos Available</h3>
            }
            </div>
        </div>
    </div>
</div>

        </div>

