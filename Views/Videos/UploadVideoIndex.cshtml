
@{

    Layout = null;
}


<div class="row">
    <div class="col-md-12">
        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">New Video</h3>
            </div>
            <form id="videoform" enctype="multipart/form-data" endpoint="" redirecturlpoint="/User/Index">
                <div class="card-body">

                    <div class="form-group">
                        <label for="exampleInputFile">File input</label>
                        <div class="input-group">
                            <input type="file" id="videofile" class="form-control">

                            <div class="input-group-append">
                                <a href="#" id="uploadvideo">
                                    <span style="background-color: cornflowerblue" class="input-group-text">Upload</span>
                                </a>
                            </div>
                        </div>
                    </div>

                </div>
            </form>
            <div id="videouploadedContainer" class="ml-5">
            </div>


        </div>
</div>
</div>
