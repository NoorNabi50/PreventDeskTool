
@{ 
    Layout = null;
}
@model IEnumerable<PreventDeskTool.Models.Users>



<div class="card">
    <div class="card-header">
        <h3 class="card-title">Users</h3>
    </div>
    <div class="card-body">
        <table id="datatable" class="table table-sm table-bordered table-striped">
            <thead class="bg-blue">
                <tr>
                    <th>UserName</th>
                    <th>PhoneNo</th>
                    <th>Password</th>
                    <th>Role</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
            @foreach(PreventDeskTool.Models.Users users in Model)
            {
                <tr>
                    <td>@users.UserName</td>
                    <td>@users.PhoneNo</td>
                    <td>@users.Password</td>
                    <td>@users.Role</td>
                    <td><button type="button" class="btn btn-info">Edit</button> <button id="@users.UserId" type="button" endpoint="/User/DeleteUser" redirecturlpoint="/User/Index" class="btn btn-danger Deletebtn">Delete</button> </td>
                </tr>
            }


            </tbody>
            </table>
        
</div>

</div>
